    "system.erbium.title": "Erbium",
    "system.erbium.desc": "A silvery-white metal, vital for signal amplifiers in fiber-optic internet cables.",
    "system.erbium.fact": "Erbium is the reason the internet works across long distances. It amplifies the light signals inside fiber-optic cables.",
    "resource.wiki.erbium": "Wikipedia: Erbium",
    "resource.pubchem.erbium": "PubChem - Erbium",
    "ai.erbium.simple": "Erbium is element 68, a metal that helps your internet stay fast and makes glass look pink.",
    "ai.erbium.detailed": "Erbium is critical for global communications. Without erbium-doped amplifiers, fiber-optic signals would fade out over long distances. It is also used in skin-resurfacing lasers.",
    "ai.erbium.study.1": "Atomic Number: 68",
    "ai.erbium.study.2": "Symbol: Er",
    "ai.erbium.study.3": "Тобы: Лантаноидтар",
    "ai.erbium.study.4": "Массасы: 167.26",
    "ai.erbium.study.5": "Электрондық конфигурация: [Xe] 4f12 6s2",
    "glossary.def.7": "Атом ядросындағы протондар саны. Элементтің химиялық қасиеттерін анықтайды.",
    "glossary.sect.general": "Химический элемент",
    "glossary.term.1": "Химический элемент",
    "glossary.def.1": "Простое вещество, состоящее из одинаковых атомов. Например: кислород, железо, золото.",
    "glossary.term.2": "Молекулалық физика",
    "glossary.def.2": "Молекулалардың физикалық қасиеттерін және атомдар арасындағы химиялық байланыстарды зерттейтін физика бөлімі.",
    "glossary.term.3": "Молекула",
    "glossary.def.3": "Химиялық байланыстармен біріктірілген екі немесе одан да көп атомдар тобы.",
    "glossary.term.4": "Элемент",
    "glossary.def.4": "Ядросында протондар саны бірдей атомдардан тұратын таза зат.",
    "glossary.term.5": "Периодтық кесте",
    "glossary.def.5": "Химиялық элементтердің атомдық нөмірі мен қасиеттері бойынша реттелген кестелік көрінісі.",
    "glossary.term.6": "Химиялық тепе-теңдік",
    "glossary.def.6": "Тура және кері реакциялардың жылдамдығы тең болатын күй.",
    "glossary.term.7": "Химиялық реакция",
    "glossary.def.7": "Кейбір заттардың басқа заттарға айналу процесі.",
    "glossary.term.8": "Катализ",
    "glossary.def.8": "Катализаторды қосу арқылы химиялық реакцияны жеделдету.",
    "glossary.sect.skeletal": "Сутек және атомдық физика",
    "glossary.term.9": "Атом",
    "glossary.def.9": "Химиялық элементті құрайтын қарапайым заттың ең кіші бірлігі.",
    "glossary.term.10": "Протон",
    "glossary.def.10": "Атом ядросындағы оң заряды бар тұрақты субатомдық бөлшек.",
    "glossary.term.11": "Электрон",
    "glossary.def.11": "Теріс заряды бар тұрақты субатомдық бөлшек.",
    "glossary.term.12": "Изотоп",
    "glossary.def.12": "Нейтрондар саны әртүрлі бір элементтің формалары.",
    "glossary.term.13": "Протий",
    "glossary.def.13": "Сутегінің ең көп таралған изотопы (0 нейтрон).",
    "glossary.term.14": "Дейтерий",
    "glossary.def.14": "1 нейтроны бар сутегінің тұрақты изотопы.",
    "glossary.term.15": "Тритий",
    "glossary.def.15": "2 нейтроны бар сутегінің радиоактивті изотопы.",
    "glossary.term.16": "Сутектік байланыс",
    "glossary.def.16": "Электростатикалық тартылыс есебінен молекулалар арасындағы әлсіз байланыс.",
    "glossary.term.17": "Электртерістілік",
    "glossary.def.17": "Атомның ортақ электрон жұптарын өзіне тарту қабілеті.",
    "glossary.term.18": "Тотықсыздану",
    "glossary.def.18": "Атомның электрондарды алу процесі.",
    "glossary.term.19": "Атомдық масса",
    "glossary.def.19": "Атомдық масса бірліктерімен (м.а.б.) өрнектелген атомның массасы.",
    "glossary.term.20": "Инертті газ",
    "glossary.def.20": "18-ші топтың инертті газдары (Гелий, Неон және т.б.).",
    "glossary.sect.circulatory": "Бериллий және металдар",
    "glossary.term.21": "Атомдық нөмір 4",
    "glossary.def.21": "Бериллий — Менделеев кестесінің төртінші элементі.",
    "glossary.term.22": "Сілтілік жер металы",
    "glossary.def.22": "Бериллий жататын элементтер тобы.",
    "glossary.term.23": "Қорытпалар",
    "glossary.def.23": "Бериллий беріктік беретін металдар қоспасы.",
    "glossary.term.24": "Рентгендік терезелер",
    "glossary.def.24": "Рентген сәулелері үшін мөлдірлігіне байланысты бериллийді қолдану.",
    "glossary.sect.respiratory": "Бром және галогендер",
    "glossary.term.25": "Галогендер",
    "glossary.def.25": "17-ші топтағы химиялық белсенді бейметалдар тобы.",
    "glossary.term.26": "Сұйық бейметалл",
    "glossary.def.26": "Бромның бөлме температурасындағы ерекше күйі.",
    "glossary.term.27": "Тотықтырғыш",
    "glossary.def.27": "Химиялық реакцияда электрондарды қабылдайтын зат.",
    "glossary.sect.digestive": "Көміртек және органика",
    "glossary.term.28": "Катенация",
    "glossary.def.28": "Көміртек атомдарының ұзын тізбектер мен сақиналарға байланысу қабілеті.",
    "glossary.term.29": "Аллотропия",
    "glossary.def.29": "Бір элементтің әртүрлі формалары (алмаз, графит).",
    "glossary.term.30": "Валенттілік",
    "glossary.def.30": "Көміртек атомының 4 байланыс түзу қабілеті.",
    "glossary.term.31": "Графен",
    "glossary.def.31": "Қалыңдығы бір атом болатын көміртектің өте берік қабаты.",
    "glossary.term.32": "Көмірсутектер",
    "glossary.def.32": "Көміртек пен сутегінің қосылыстары.",
    "glossary.term.33": "Полимер",
    "glossary.def.33": "Көптеген қайталанатын буындардан тұратын зат."
}